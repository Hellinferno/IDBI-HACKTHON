# Orchestrator environment. Copy to .env and fill in. .env is gitignored.

# Google Gemini (LLM that phrases answers; numbers still come from the engine)
GEMINI_API_KEY=
# gemini-2.5-flash works on free-tier projects; 2.0-flash may show "limit: 0".
GEMINI_MODEL=gemini-2.5-flash

# Where the Python computation engine is reachable
COMPUTATION_ENGINE_URL=http://localhost:8001

# Server
PORT=8005

# CORS origin for the deployed web demo ("*" is fine for the hackathon)
CORS_ORIGIN=*
